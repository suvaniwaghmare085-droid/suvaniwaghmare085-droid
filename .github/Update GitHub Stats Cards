name: Update GitHub Stats Cards
on:
  schedule:
    - cron: "0 3 * * *"   # runs daily at 3am
  workflow_dispatch:        # lets you run it manually too

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Generate stats card
        uses: readme-tools/github-readme-stats-action@v1
        with:
          card: stats
          options: username=suvaniwaghmare085-droid&show_icons=true&theme=radical&hide_border=true&count_private=true
          path: assets/stats.svg
          token: ${{ secrets.GITHUB_TOKEN }}
      - name: Generate top languages card
        uses: readme-tools/github-readme-stats-action@v1
        with:
          card: top-langs
          options: username=suvaniwaghmare085-droid&layout=compact&theme=radical&hide_border=true
          path: assets/langs.svg
          token: ${{ secrets.GITHUB_TOKEN }}
      - name: Commit cards
        run: |
          git config user.name "github-actions"
          git config user.email "github-actions@users.noreply.github.com"
          git add assets/*.svg
          git commit -m "Update stats cards" || exit 0
          git push
